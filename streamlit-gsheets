from streamlit_gsheets import GSheetsConnection
import streamlit as st

# Crear la conexión con Google Sheets
conn = st.connection("gsheets", type=GSheetsConnection)

# Leer los datos directamente de la URL de Google Drive
# Solo necesitas poner la URL de tu hoja aquí o en los secretos
df_analisis = conn.read(spreadsheet="https://docs.google.com/spreadsheets/d/1CEUJ61N4e28FqjMUhCB8c4YPNzl8u8nlqYjf8kmVVqk/edit?usp=sharing")

st.write("Datos desde Google Drive:")
st.dataframe(df_analisis)
