import streamlit as st
from streamlit_gsheets import GSheetsConnection

st.title("D'UNIG: Tu Asistente en la Nube")

# Crear la conexión
conn = st.connection("gsheets", type=GSheetsConnection)

# Leer los datos (Asegúrate de que el link sea el correcto)
url = "https://docs.google.com/spreadsheets/d/1CEUJ61N4e28FqjMUhCB8c4YPNzl8u8nlqYjf8kmVVqk/edit?usp=sharing"
df_analisis = conn.read(spreadsheet=url, ttl=0)

st.write("Datos desde Google Drive:")
st.dataframe(df_analisis)
